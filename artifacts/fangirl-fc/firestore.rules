rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Share records — anyone can read (friends open links), only auth users can write
    match /shares/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['shareId', 'identityId', 'stars', 'teamCode', 'displayName', 'templateId', 'createdAt'])
                    && request.resource.data.shareId == shareId;
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.get('userId', '');
    }

    // Per-user profile data (stars, unlocks, official card, official team)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
