rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Share records — anyone can read, only auth users can create/update/delete their own
    match /shares/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['shareId', 'identityId', 'stars', 'teamCode', 'displayName', 'templateId', 'createdAt'])
                    && request.resource.data.shareId == shareId;
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.get('userId', '');
    }

    // Per-user profile — owner only (includes official stars, official card, star action log)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public leaderboard — safe fields only (no email)
    // Anyone can read; only the matching auth user can write their own entry
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
