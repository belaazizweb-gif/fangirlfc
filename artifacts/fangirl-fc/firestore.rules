rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Share records ─────────────────────────────────────────────────────────
    // Public read; auth users can create/update/delete their own shares.
    match /shares/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll([
                         'shareId', 'identityId', 'stars', 'teamCode',
                         'displayName', 'templateId', 'createdAt'
                       ])
                    && request.resource.data.shareId == shareId;
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.get('userId', '');
    }

    // ── Official share analytics ──────────────────────────────────────────────
    // Analytics/debug collection — NOT reward authority.
    // Authenticated users can read (for social proof feed + recent activity).
    // Auth user can create their own record; no update/delete.
    match /official_shares/{shareId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.shareId == shareId
                    && request.resource.data.keys().hasAll([
                         'shareId', 'uid', 'identityId', 'templateId',
                         'displayName', 'shareUrl', 'createdAt'
                       ])
                    && !request.resource.data.keys().hasAny(['officialStars', 'officialXp', 'rankScore']);
      allow update, delete: if false;
    }

    // ── Per-user profile ──────────────────────────────────────────────────────
    // Owner read/write — progression fields only writable by Cloud Function.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny([
                         'officialStars', 'officialXp', 'rankScore', 'officialStarActions'
                       ]);

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['officialStars', 'officialXp', 'rankScore', 'officialStarActions']);
    }

    // ── Public individual leaderboard ─────────────────────────────────────────
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Team ranking aggregate ────────────────────────────────────────────────
    match /teams/{teamCode} {
      allow read: if true;

      allow create: if request.auth != null
                    && !request.resource.data.keys().hasAny([
                         'totalStars', 'totalXp', 'rankScore'
                       ]);

      allow update: if request.auth != null
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['totalStars', 'totalXp', 'rankScore']);
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
